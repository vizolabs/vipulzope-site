---
import Layout from '../../layouts/Layout.astro';

export function getStaticPaths() {
  const postFiles = import.meta.glob('./*.md', { eager: true });

  return Object.entries(postFiles).map(([path, module]) => ({
    params: { slug: path.replace('.md', '').replace('./', '') },
    props: { post: module },
  }));
}

const { post } = Astro.props;
const { frontmatter, compiledContent } = post;
---

<Layout title={`${frontmatter.title} | Vipul Zope`} description={frontmatter.description}>
  <article class="max-w-3xl mx-auto px-6 py-16">
    <a href="/blog" class="text-[var(--color-accent)] hover:underline text-sm mb-6 inline-block">&larr; Back to Blog</a>

    <header class="mb-8">
      <h1 class="text-3xl font-bold mb-3">{frontmatter.title}</h1>
      <div class="flex items-center gap-4 text-sm text-[var(--color-text-muted)]">
        <time>
          {new Date(frontmatter.date).toLocaleDateString('en-US', {
            year: 'numeric',
            month: 'long',
            day: 'numeric',
          })}
        </time>
        {frontmatter.tags && (
          <div class="flex gap-2">
            {frontmatter.tags.map((tag: string) => (
              <span class="px-2 py-0.5 bg-[var(--color-bg-card)] border border-[var(--color-border)] rounded text-xs">{tag}</span>
            ))}
          </div>
        )}
      </div>
    </header>

    <div class="prose prose-invert max-w-none" set:html={compiledContent()} />
  </article>
</Layout>

<style>
  .prose :global(h1) { font-size: 1.875rem; font-weight: 700; margin-top: 2rem; margin-bottom: 1rem; }
  .prose :global(h2) { font-size: 1.5rem; font-weight: 700; margin-top: 2rem; margin-bottom: 0.75rem; }
  .prose :global(h3) { font-size: 1.25rem; font-weight: 600; margin-top: 1.5rem; margin-bottom: 0.5rem; }
  .prose :global(p) { margin-bottom: 1rem; line-height: 1.75; color: var(--color-text-muted); }
  .prose :global(a) { color: var(--color-accent); text-decoration: underline; }
  .prose :global(strong) { color: var(--color-text); }
  .prose :global(code) { background: var(--color-bg-card); padding: 0.2em 0.4em; border-radius: 0.25rem; font-size: 0.875em; }
  .prose :global(pre) { background: var(--color-bg-card); border: 1px solid var(--color-border); border-radius: 0.75rem; padding: 1rem; overflow-x: auto; margin-bottom: 1.5rem; }
  .prose :global(pre code) { background: none; padding: 0; }
  .prose :global(ul) { list-style: disc; padding-left: 1.5rem; margin-bottom: 1rem; color: var(--color-text-muted); }
  .prose :global(ol) { list-style: decimal; padding-left: 1.5rem; margin-bottom: 1rem; color: var(--color-text-muted); }
  .prose :global(li) { margin-bottom: 0.25rem; }
  .prose :global(blockquote) { border-left: 3px solid var(--color-accent); padding-left: 1rem; margin-left: 0; margin-bottom: 1rem; color: var(--color-text-muted); font-style: italic; }
</style>
