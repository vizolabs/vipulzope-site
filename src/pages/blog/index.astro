---
import Layout from '../../layouts/Layout.astro';

const posts = [
  {
    url: '/blog/hello-world',
    title: 'Hello World',
    date: '2026-06-29',
    description: 'My first blog post on my new personal website. Here\'s why I built it and what\'s coming next.',
  },
];
---

<Layout title="Blog | Vipul Zope">
  <section class="max-w-4xl mx-auto px-6 py-16">
    <h1 class="text-3xl font-bold mb-4">Blog</h1>
    <p class="text-[var(--color-text-muted)] mb-10">Thoughts on code, tech, and the journey of building things.</p>

    <div class="space-y-6">
      {posts.map(post => (
        <a
          href={post.url}
          class="block bg-[var(--color-bg-card)] border border-[var(--color-border)] rounded-xl p-6 hover:border-[var(--color-accent)] transition-colors group"
        >
          <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2 mb-2">
            <h2 class="text-xl font-semibold group-hover:text-[var(--color-accent)] transition-colors">
              {post.title}
            </h2>
            <time class="text-sm text-[var(--color-text-muted)]">
              {new Date(post.date).toLocaleDateString('en-US', {
                year: 'numeric',
                month: 'long',
                day: 'numeric',
              })}
            </time>
          </div>
          <p class="text-[var(--color-text-muted)]">{post.description}</p>
        </a>
      ))}
    </div>
  </section>
</Layout>
