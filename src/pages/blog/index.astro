---
import Layout from '../../layouts/Layout.astro';

const posts = [
  {
    url: '/blog/hello-world',
    title: 'hello world',
    date: 'Jun 29, 2026',
  },
];
---

<Layout title="Blog | Vipul Zope">
  <div class="max-w-[650px] mx-auto px-6 py-12">
    <h1 class="text-2xl font-bold mb-6">Blog</h1>

    <ul class="space-y-1">
      {posts.map(post => (
        <li class="flex items-baseline justify-between gap-4">
          <a href={post.url} class="text-[var(--color-text)] hover:text-[var(--color-accent)] no-underline hover:underline">
            {post.title}
          </a>
          <span class="text-sm text-[var(--color-text-muted)] shrink-0">{post.date}</span>
        </li>
      ))}
    </ul>
  </div>
</Layout>
