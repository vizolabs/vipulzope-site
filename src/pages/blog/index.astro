---
import Layout from '../../layouts/Layout.astro';

const posts = [
  {
    url: '/blog/rules-to-loops',
    title: 'the quiet shift: how ai operations moved from rules to loops',
    date: '25 Jun 2026',
  },
  {
    url: '/blog/real-vs-hype',
    title: 'the honest version: separating loop engineering from its hype',
    date: '29 Jun 2026',
  },
  {
    url: '/blog/practical-ai-ops',
    title: 'the playbook: what an operations team would actually build',
    date: '3 Jul 2026',
  },
];
---

<Layout title="Blog | Vipul Zope">
  <div class="max-w-[700px] mx-auto px-6 py-8 sm:py-12">
    <h1 class="font-serif font-semibold text-[2rem] leading-[1.15] text-[var(--color-ink)] mb-8">Blog</h1>

    <ul class="list-none p-0 space-y-0">
      {posts.map(post => (
        <li>
          <a
            href={post.url}
            class="flex items-baseline justify-between gap-4 py-4 border-b border-[var(--color-border)] last:border-none no-underline group"
          >
            <div>
              <span class="font-serif text-[1.1rem] italic text-[var(--color-ink)] group-hover:text-[var(--color-accent)] transition-colors duration-200">
                {post.title}
              </span>
            </div>
            <span class="font-mono text-[0.62rem] text-[var(--color-ink-muted)] tracking-[0.04em] shrink-0">
              {post.date}
            </span>
          </a>
        </li>
      ))}
    </ul>
  </div>
</Layout>
