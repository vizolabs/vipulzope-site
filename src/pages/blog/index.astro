---
import Layout from '../../layouts/Layout.astro';

const posts = [
  {
    url: '/blog/intelligence-stack-part-1',
    title: 'from rules to loops: the quiet evolution of ai in operations',
    date: 'Jul 2, 2026',
    series: 'Part 1',
  },
  {
    url: '/blog/intelligence-stack-part-2',
    title: 'loop engineering: what\'s real, what\'s hype, and what\'s unknown',
    date: 'Jul 2, 2026',
    series: 'Part 2',
  },
  {
    url: '/blog/intelligence-stack-part-3',
    title: 'a practical framework for building operational loops',
    date: 'Jul 2, 2026',
    series: 'Part 3',
  },
];
---

<Layout title="Blog | Vipul Zope">
  <div class="max-w-[700px] mx-auto px-6 py-8 sm:py-12">
    <h1 class="font-serif font-semibold text-[2rem] leading-[1.15] text-[var(--color-ink)] mb-8">Blog</h1>

    <ul class="list-none p-0 space-y-0">
      {posts.map(post => (
        <li>
          <a
            href={post.url}
            class="flex items-baseline justify-between gap-4 py-4 border-b border-[var(--color-border)] last:border-none no-underline group"
          >
            <div>
              <span class="block font-mono text-[0.55rem] tracking-[0.15em] uppercase text-[var(--color-accent)] mb-1">
                {post.series}
              </span>
              <span class="font-serif text-[1.1rem] italic text-[var(--color-ink)] group-hover:text-[var(--color-accent)] transition-colors duration-200">
                {post.title}
              </span>
            </div>
            <span class="font-mono text-[0.62rem] text-[var(--color-ink-muted)] tracking-[0.04em] shrink-0">
              {post.date}
            </span>
          </a>
        </li>
      ))}
    </ul>
  </div>
</Layout>
