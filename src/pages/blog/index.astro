---
import Layout from '../../layouts/Layout.astro';

const postFiles = import.meta.glob('./*.md', { eager: true });

const posts = Object.entries(postFiles).map(([path, module]) => ({
  url: path.replace('.md', '').replace('./', '/blog/'),
  frontmatter: module.frontmatter,
}));

const sortedPosts = posts.sort(
  (a, b) => new Date(b.frontmatter.date).valueOf() - new Date(a.frontmatter.date).valueOf()
);
---

<Layout title="Blog | Vipul Zope">
  <section class="max-w-4xl mx-auto px-6 py-16">
    <h1 class="text-3xl font-bold mb-4">Blog</h1>
    <p class="text-[var(--color-text-muted)] mb-10">Thoughts on code, tech, and the journey of building things.</p>

    {sortedPosts.length === 0 ? (
      <div class="bg-[var(--color-bg-card)] border border-[var(--color-border)] rounded-xl p-10 text-center">
        <p class="text-[var(--color-text-muted)] text-lg">No posts yet. Stay tuned!</p>
      </div>
    ) : (
      <div class="space-y-6">
        {sortedPosts.map(post => (
          <a
            href={post.url}
            class="block bg-[var(--color-bg-card)] border border-[var(--color-border)] rounded-xl p-6 hover:border-[var(--color-accent)] transition-colors group"
          >
            <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2 mb-2">
              <h2 class="text-xl font-semibold group-hover:text-[var(--color-accent)] transition-colors">
                {post.frontmatter.title}
              </h2>
              <time class="text-sm text-[var(--color-text-muted)]">
                {new Date(post.frontmatter.date).toLocaleDateString('en-US', {
                  year: 'numeric',
                  month: 'long',
                  day: 'numeric',
                })}
              </time>
            </div>
            <p class="text-[var(--color-text-muted)]">{post.frontmatter.description}</p>
          </a>
        ))}
      </div>
    )}
  </section>
</Layout>
