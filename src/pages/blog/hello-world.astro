---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="hello world | Vipul Zope" description="my first blog post.">
  <article class="max-w-[650px] mx-auto px-6 py-12">
    <a href="/blog" class="text-sm text-[var(--color-text-muted)] hover:text-[var(--color-accent)] no-underline hover:underline">&larr; back</a>

    <header class="mt-4 mb-8">
      <h1 class="text-2xl font-bold mb-2">hello world</h1>
      <time class="text-sm text-[var(--color-text-muted)]">June 29, 2026</time>
    </header>

    <div class="space-y-4 text-[var(--color-text)] leading-relaxed">
      <p>welcome to my blog. this is my first post on <strong>vipulzope.in</strong> — built with Astro, hosted on GitHub Pages.</p>

      <p>i built this site to have my own corner of the internet. a place to write, share thoughts, and document the journey.</p>

      <p>more coming soon.</p>
    </div>
  </article>
</Layout>
