---
import Layout from '../layouts/Layout.astro';

const projects = [
  {
    title: 'Project Alpha',
    description: 'A full-stack web application built with modern tools. Features real-time updates and a clean UI.',
    tech: ['Astro', 'TypeScript', 'Tailwind'],
    github: 'https://github.com/vizolabs',
    live: '#',
  },
  {
    title: 'Project Beta',
    description: 'An open-source CLI tool for developers. Streamlines common development workflows.',
    tech: ['Node.js', 'CLI', 'npm'],
    github: 'https://github.com/vizolabs',
    live: null,
  },
  {
    title: 'Project Gamma',
    description: 'A personal finance tracker with charts and insights. Built to learn data visualization.',
    tech: ['React', 'Chart.js', 'Firebase'],
    github: 'https://github.com/vizolabs',
    live: '#',
  },
  {
    title: 'Project Delta',
    description: 'A minimal note-taking app with markdown support. Clean, fast, and distraction-free.',
    tech: ['TypeScript', 'LocalStorage', 'CSS'],
    github: 'https://github.com/vizolabs',
    live: '#',
  },
];
---

<Layout title="Projects | Vipul Zope">
  <section class="max-w-4xl mx-auto px-6 py-16">
    <h1 class="text-3xl font-bold mb-4">Projects</h1>
    <p class="text-[var(--color-text-muted)] mb-10">A collection of things I've built and worked on.</p>

    <div class="grid gap-6">
      {projects.map(project => (
        <div class="bg-[var(--color-bg-card)] border border-[var(--color-border)] rounded-xl p-6 hover:border-[var(--color-accent)] transition-colors">
          <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-3">
            <h2 class="text-xl font-semibold">{project.title}</h2>
            <div class="flex gap-3">
              {project.github && (
                <a href={project.github} target="_blank" rel="noopener" class="text-sm text-[var(--color-text-muted)] hover:text-[var(--color-accent)] transition-colors">
                  GitHub &rarr;
                </a>
              )}
              {project.live && (
                <a href={project.live} target="_blank" rel="noopener" class="text-sm text-[var(--color-text-muted)] hover:text-[var(--color-accent)] transition-colors">
                  Live &rarr;
                </a>
              )}
            </div>
          </div>
          <p class="text-[var(--color-text-muted)] mb-4">{project.description}</p>
          <div class="flex gap-2 flex-wrap">
            {project.tech.map(t => (
              <span class="text-xs px-3 py-1 bg-[var(--color-bg)] rounded-full text-[var(--color-accent)]">{t}</span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>
</Layout>
