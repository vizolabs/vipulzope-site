---
import Layout from '../layouts/Layout.astro';

const posts = [
  {
    url: '/blog/hello-world',
    title: 'hello world',
    date: 'Jun 29, 2026',
  },
];

const links = [
  { label: 'X', url: 'https://x.com/zope_vipul' },
  { label: 'GitHub', url: 'https://github.com/vizolabs' },
  { label: 'LinkedIn', url: 'https://linkedin.com/in/vipulzope' },
  { label: 'cal.com/vipulzope', url: 'https://cal.com/vipulzope' },
];
---

<Layout title="Vipul Zope">
  <div class="max-w-[650px] mx-auto px-6 py-12">

    <h1 class="text-2xl font-bold mb-2">hey! i'm vipul.</h1>

    <p class="text-[var(--color-text-muted)] mb-8">
      i'm a 22-year-old operator and systems builder. i believe the next decade of Physical AI and Robotics will be won by those who control the Data Supply Chain.
    </p>

    <section class="mb-10">
      <h2 class="text-sm font-semibold uppercase tracking-wider text-[var(--color-text-muted)] mb-3">Problems I Find Interesting</h2>
      <ul class="space-y-3 text-[var(--color-text)]">
        <li><strong>industrial data pipelines (B2B):</strong> securing proprietary, high-fidelity tactile data by integrating multimodal sensors into heavy manufacturing and factory workflows.</li>
        <li><strong>decentralized data scaling:</strong> removing the entropy from high-volume, community-led gig-worker networks to capture infinite real-world spatial variability via mobile head-mounts.</li>
        <li><strong>sim-to-real ecosystems:</strong> designing incentivized digital platforms where massive communities bridge the gap between simulated tasks and physical ground-truth.</li>
        <li><strong>operationalized intelligence:</strong> the pure logistics of managing a multi-tiered supply chain—turning chaotic human movement across factories and streets into structured robotic policies.</li>
      </ul>
    </section>

    <section class="mb-10">
      <h2 class="text-sm font-semibold uppercase tracking-wider text-[var(--color-text-muted)] mb-3">Before Now</h2>
      <ul class="space-y-3 text-[var(--color-text)]">
        <li>orchestrated mega-scale recruitment as <strong>Lead at Placecom</strong> — managed hiring pipelines for IBM, HP, Bentley, Mercedes-Benz, Bosch, and TCS. moved thousands of candidates through corporate funnels for 30+ global giants.</li>
        <li>built founding ops at <strong>OP OFFICIALS</strong> (110k subscribers) — scaled a community to 74k discord members.</li>
        <li>led a freelance unit <strong>StreamEase</strong> — managed a high-output squad to build a network of 78+ creators for Loco, Rooter, JioGames, Chingari and Rumble.</li>
        <li>managed a regulatory exit — navigated the 2022 Govt ban which forced an exit after 20 months of growth and partnerships with Monster Energy, Redbull, Spinbot, Loco, Rooter, etc.</li>
        <li>*secured <strong>Mathematics AIR 26</strong> and <strong>Overall AIR 99</strong> in the National Level Science Talent Search Examination</li>
      </ul>
    </section>

    <section class="mb-10">
      <h2 class="text-sm font-semibold uppercase tracking-wider text-[var(--color-text-muted)] mb-3">// early_signals</h2>
      <div class="space-y-4 text-[var(--color-text)] leading-relaxed">
        <p>i've been a conductor of chaos since i was a kid. as a School Band Leader, i played drums and bass for annual parades and guest welcomes—learning the high-stakes timing of live performance. i spent my teens as a Pro-Gamer learning strategy under pressure. i model my execution style after Rohit Sharma: calm leadership, selfless strategy, and relentless power when it's time to hit.</p>
        <p>i just finished my computer engineering degree (Honours in Data Science). i took a brief career pause post-graduation to handle a critical family medical emergency—that responsibility is now fully resolved and i am back in the arena.</p>
        <p class="font-semibold">i am ready to burn the boats.</p>
        <p>i am currently slated to enter a B-School in a few weeks, but i am looking for the right mission to drop out for. if you are building something massive in Physical AI, Robotics, or Data Infrastructure—let's talk.</p>
      </div>
    </section>

    <section class="mb-10">
      <h2 class="text-sm font-semibold uppercase tracking-wider text-[var(--color-text-muted)] mb-3">Links</h2>
      <ul class="space-y-1">
        {links.map(link => (
          <li>
            <a href={link.url} target="_blank" rel="noopener">{link.label} &rarr;</a>
          </li>
        ))}
      </ul>
    </section>

    <section>
      <h2 class="text-sm font-semibold uppercase tracking-wider text-[var(--color-text-muted)] mb-3">Thoughts</h2>
      <ul class="space-y-1">
        {posts.map(post => (
          <li class="flex items-baseline justify-between gap-4">
            <a href={post.url} class="text-[var(--color-text)] hover:text-[var(--color-accent)] no-underline hover:underline">
              {post.title}
            </a>
            <span class="text-sm text-[var(--color-text-muted)] shrink-0">{post.date}</span>
          </li>
        ))}
      </ul>
    </section>

  </div>
</Layout>
