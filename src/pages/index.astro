---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Vipul Zope | Personal Website">
  <!-- Hero Section -->
  <section class="max-w-4xl mx-auto px-6 pt-20 pb-16">
    <div class="flex flex-col items-center text-center gap-6">
      <div class="w-28 h-28 rounded-full bg-[var(--color-bg-card)] border-2 border-[var(--color-accent)] flex items-center justify-center text-4xl font-bold text-[var(--color-accent)]">
        VZ
      </div>
      <div>
        <h1 class="text-4xl sm:text-5xl font-bold mb-4">
          Hi, I'm <span class="text-[var(--color-accent)]">Vipul Zope</span>
        </h1>
        <p class="text-lg text-[var(--color-text-muted)] max-w-xl mx-auto">
          Developer, creator, and lifelong learner. Building things that matter.
        </p>
      </div>
      <div class="flex gap-4 mt-4">
        <a href="/projects" class="px-6 py-3 bg-[var(--color-primary)] hover:bg-[var(--color-primary-dark)] text-white rounded-lg font-medium transition-colors">
          View Projects
        </a>
        <a href="/contact" class="px-6 py-3 border border-[var(--color-border)] hover:border-[var(--color-accent)] text-[var(--color-text)] rounded-lg font-medium transition-colors">
          Get in Touch
        </a>
      </div>
    </div>
  </section>

  <!-- About Preview -->
  <section class="max-w-4xl mx-auto px-6 py-16">
    <h2 class="text-2xl font-bold mb-8 text-center">What I Do</h2>
    <div class="grid sm:grid-cols-3 gap-6">
      <div class="bg-[var(--color-bg-card)] border border-[var(--color-border)] rounded-xl p-6 hover:border-[var(--color-accent)] transition-colors">
        <div class="text-3xl mb-4">💻</div>
        <h3 class="font-semibold mb-2">Development</h3>
        <p class="text-sm text-[var(--color-text-muted)]">Building web applications and tools with modern technologies.</p>
      </div>
      <div class="bg-[var(--color-bg-card)] border border-[var(--color-border)] rounded-xl p-6 hover:border-[var(--color-accent)] transition-colors">
        <div class="text-3xl mb-4">🎨</div>
        <h3 class="font-semibold mb-2">Design</h3>
        <p class="text-sm text-[var(--color-text-muted)]">Creating clean, intuitive interfaces that users love.</p>
      </div>
      <div class="bg-[var(--color-bg-card)] border border-[var(--color-border)] rounded-xl p-6 hover:border-[var(--color-accent)] transition-colors">
        <div class="text-3xl mb-4">📝</div>
        <h3 class="font-semibold mb-2">Writing</h3>
        <p class="text-sm text-[var(--color-text-muted)]">Sharing thoughts on tech, code, and the journey of building.</p>
      </div>
    </div>
  </section>

  <!-- Recent Projects Preview -->
  <section class="max-w-4xl mx-auto px-6 py-16">
    <h2 class="text-2xl font-bold mb-8 text-center">Recent Projects</h2>
    <div class="grid sm:grid-cols-2 gap-6">
      <a href="/projects" class="group bg-[var(--color-bg-card)] border border-[var(--color-border)] rounded-xl p-6 hover:border-[var(--color-accent)] transition-colors">
        <h3 class="font-semibold mb-2 group-hover:text-[var(--color-accent)] transition-colors">Project Alpha</h3>
        <p class="text-sm text-[var(--color-text-muted)] mb-4">A full-stack web application built with modern tools.</p>
        <div class="flex gap-2 flex-wrap">
          <span class="text-xs px-2 py-1 bg-[var(--color-bg)] rounded-md text-[var(--color-accent)]">Astro</span>
          <span class="text-xs px-2 py-1 bg-[var(--color-bg)] rounded-md text-[var(--color-accent)]">TypeScript</span>
        </div>
      </a>
      <a href="/projects" class="group bg-[var(--color-bg-card)] border border-[var(--color-border)] rounded-xl p-6 hover:border-[var(--color-accent)] transition-colors">
        <h3 class="font-semibold mb-2 group-hover:text-[var(--color-accent)] transition-colors">Project Beta</h3>
        <p class="text-sm text-[var(--color-text-muted)] mb-4">An open-source CLI tool for developers.</p>
        <div class="flex gap-2 flex-wrap">
          <span class="text-xs px-2 py-1 bg-[var(--color-bg)] rounded-md text-[var(--color-accent)]">Node.js</span>
          <span class="text-xs px-2 py-1 bg-[var(--color-bg)] rounded-md text-[var(--color-accent)]">CLI</span>
        </div>
      </a>
    </div>
  </section>

  <!-- CTA -->
  <section class="max-w-4xl mx-auto px-6 py-16 text-center">
    <div class="bg-[var(--color-bg-card)] border border-[var(--color-border)] rounded-2xl p-10">
      <h2 class="text-2xl font-bold mb-4">Let's Connect</h2>
      <p class="text-[var(--color-text-muted)] mb-6">Have a project in mind or just want to say hi? I'd love to hear from you.</p>
      <a href="/contact" class="inline-block px-6 py-3 bg-[var(--color-primary)] hover:bg-[var(--color-primary-dark)] text-white rounded-lg font-medium transition-colors">
        Send a Message
      </a>
    </div>
  </section>
</Layout>
