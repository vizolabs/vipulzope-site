---
import Layout from '../layouts/Layout.astro';
---

<Layout title="About | Vipul Zope">
  <section class="max-w-4xl mx-auto px-6 py-16">
    <h1 class="text-3xl font-bold mb-8">About Me</h1>

    <div class="prose prose-invert max-w-none">
      <div class="bg-[var(--color-bg-card)] border border-[var(--color-border)] rounded-xl p-8 mb-8">
        <p class="text-lg text-[var(--color-text-muted)] leading-relaxed">
          Hey! I'm <strong class="text-[var(--color-text)]">Vipul Zope</strong> — a developer based in India.
          I love building things for the web and exploring new technologies.
          This website is my little corner of the internet where I share my projects, thoughts, and learnings.
        </p>
      </div>

      <h2 class="text-2xl font-bold mt-12 mb-6">Skills & Technologies</h2>
      <div class="grid sm:grid-cols-2 gap-4 mb-12">
        <div class="bg-[var(--color-bg-card)] border border-[var(--color-border)] rounded-xl p-5">
          <h3 class="font-semibold mb-3 text-[var(--color-accent)]">Frontend</h3>
          <div class="flex flex-wrap gap-2">
            {['HTML', 'CSS', 'JavaScript', 'TypeScript', 'React', 'Astro', 'Tailwind CSS'].map(skill => (
              <span class="text-xs px-3 py-1.5 bg-[var(--color-bg)] rounded-full text-[var(--color-text-muted)]">{skill}</span>
            ))}
          </div>
        </div>
        <div class="bg-[var(--color-bg-card)] border border-[var(--color-border)] rounded-xl p-5">
          <h3 class="font-semibold mb-3 text-[var(--color-accent)]">Backend</h3>
          <div class="flex flex-wrap gap-2">
            {['Node.js', 'Python', 'Git', 'Linux', 'REST APIs'].map(skill => (
              <span class="text-xs px-3 py-1.5 bg-[var(--color-bg)] rounded-full text-[var(--color-text-muted)]">{skill}</span>
            ))}
          </div>
        </div>
      </div>

      <h2 class="text-2xl font-bold mt-12 mb-6">Timeline</h2>
      <div class="space-y-6">
        <div class="flex gap-4">
          <div class="flex flex-col items-center">
            <div class="w-3 h-3 rounded-full bg-[var(--color-accent)]"></div>
            <div class="w-px flex-1 bg-[var(--color-border)]"></div>
          </div>
          <div class="pb-6">
            <p class="text-sm text-[var(--color-accent)] font-medium">2026</p>
            <p class="font-semibold">Started this website</p>
            <p class="text-sm text-[var(--color-text-muted)]">Built with Astro and deployed on GitHub Pages.</p>
          </div>
        </div>
        <div class="flex gap-4">
          <div class="flex flex-col items-center">
            <div class="w-3 h-3 rounded-full bg-[var(--color-border)]"></div>
          </div>
          <div>
            <p class="text-sm text-[var(--color-text-muted)] font-medium">More entries coming soon...</p>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
