---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact | Vipul Zope">
  <div class="max-w-[650px] mx-auto px-6 py-12">
    <h1 class="text-2xl font-bold mb-6">Contact</h1>

    <div class="space-y-4">
      <div>
        <h2 class="text-sm font-semibold uppercase tracking-wider text-[var(--color-text-muted)] mb-1">Email</h2>
        <a href="mailto:contactzope@gmail.com">contactzope@gmail.com</a>
      </div>

      <div>
        <h2 class="text-sm font-semibold uppercase tracking-wider text-[var(--color-text-muted)] mb-1">Schedule</h2>
        <a href="https://cal.com/vipulzope" target="_blank" rel="noopener">cal.com/vipulzope</a>
      </div>

      <div>
        <h2 class="text-sm font-semibold uppercase tracking-wider text-[var(--color-text-muted)] mb-1">Social</h2>
        <ul class="space-y-1">
          <li><a href="https://x.com/zope_vipul" target="_blank" rel="noopener">X &rarr;</a></li>
          <li><a href="https://github.com/vizolabs" target="_blank" rel="noopener">GitHub &rarr;</a></li>
          <li><a href="https://linkedin.com/in/vipulzope" target="_blank" rel="noopener">LinkedIn &rarr;</a></li>
        </ul>
      </div>
    </div>
  </div>
</Layout>
