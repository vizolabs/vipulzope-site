---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact | Vipul Zope">
  <div class="max-w-[700px] mx-auto px-6 py-8 sm:py-12">
    <h1 class="font-serif font-semibold text-[2rem] leading-[1.15] text-[var(--color-ink)] mb-8">Contact</h1>

    <div class="space-y-6">
      <div>
        <h2 class="font-mono text-[0.7rem] font-medium tracking-[0.18em] uppercase text-[var(--color-ink-muted)] mb-2">Email</h2>
        <a href="mailto:contactzope@gmail.com" class="text-[1rem] text-[var(--color-ink)] hover:text-[var(--color-accent)] underline underline-offset-3 decoration-[var(--color-accent-light)] hover:decoration-[var(--color-accent)] transition-all duration-200">
          contactzope@gmail.com
        </a>
      </div>

      <div>
        <h2 class="font-mono text-[0.7rem] font-medium tracking-[0.18em] uppercase text-[var(--color-ink-muted)] mb-2">Schedule</h2>
        <a href="https://cal.com/vipulzope" target="_blank" rel="noopener" class="text-[1rem] text-[var(--color-ink)] hover:text-[var(--color-accent)] underline underline-offset-3 decoration-[var(--color-accent-light)] hover:decoration-[var(--color-accent)] transition-all duration-200">
          cal.com/vipulzope
        </a>
      </div>

    </div>
  </div>
</Layout>
