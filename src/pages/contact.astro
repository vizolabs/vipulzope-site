---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact | Vipul Zope">
  <section class="max-w-4xl mx-auto px-6 py-16">
    <h1 class="text-3xl font-bold mb-4">Get in Touch</h1>
    <p class="text-[var(--color-text-muted)] mb-10">Have a question, idea, or just want to say hi? Drop me a message.</p>

    <div class="grid sm:grid-cols-2 gap-10">
      <!-- Contact Form via Formspree -->
      <form
        action="https://formspree.io/f/meebzlna"
        method="POST"
        class="bg-[var(--color-bg-card)] border border-[var(--color-border)] rounded-xl p-6 flex flex-col gap-4"
      >
        <div>
          <label for="name" class="block text-sm font-medium mb-1">Name</label>
          <input
            type="text"
            id="name"
            name="name"
            required
            class="w-full px-4 py-2 bg-[var(--color-bg)] border border-[var(--color-border)] rounded-lg text-[var(--color-text)] focus:outline-none focus:border-[var(--color-accent)] transition-colors"
          />
        </div>
        <div>
          <label for="email" class="block text-sm font-medium mb-1">Email</label>
          <input
            type="email"
            id="email"
            name="email"
            required
            class="w-full px-4 py-2 bg-[var(--color-bg)] border border-[var(--color-border)] rounded-lg text-[var(--color-text)] focus:outline-none focus:border-[var(--color-accent)] transition-colors"
          />
        </div>
        <div>
          <label for="message" class="block text-sm font-medium mb-1">Message</label>
          <textarea
            id="message"
            name="message"
            rows="5"
            required
            class="w-full px-4 py-2 bg-[var(--color-bg)] border border-[var(--color-border)] rounded-lg text-[var(--color-text)] focus:outline-none focus:border-[var(--color-accent)] transition-colors resize-none"
          ></textarea>
        </div>
        <button
          type="submit"
          class="px-6 py-3 bg-[var(--color-primary)] hover:bg-[var(--color-primary-dark)] text-white rounded-lg font-medium transition-colors"
        >
          Send Message
        </button>
      </form>

      <!-- Contact Info -->
      <div class="flex flex-col gap-6">
        <div class="bg-[var(--color-bg-card)] border border-[var(--color-border)] rounded-xl p-6">
          <h3 class="font-semibold mb-2">Email</h3>
          <a href="mailto:contact@vipulzope.in" class="text-[var(--color-accent)] hover:underline">contact@vipulzope.in</a>
        </div>
        <div class="bg-[var(--color-bg-card)] border border-[var(--color-border)] rounded-xl p-6">
          <h3 class="font-semibold mb-2">GitHub</h3>
          <a href="https://github.com/vizolabs" target="_blank" rel="noopener" class="text-[var(--color-accent)] hover:underline">github.com/vizolabs</a>
        </div>
        <div class="bg-[var(--color-bg-card)] border border-[var(--color-border)] rounded-xl p-6">
          <h3 class="font-semibold mb-2">Based in</h3>
          <p class="text-[var(--color-text-muted)]">India</p>
        </div>
      </div>
    </div>
  </section>
</Layout>
