---
---

<div id="password-lock" style="display:none;position:fixed;inset:0;z-index:10000;background-color:#f8f5ef;opacity:1;pointer-events:auto;">
  <div style="position:absolute;inset:0;background:#f8f5ef;"></div>
  <div style="position:relative;z-index:1;display:flex;align-items:center;justify-content:center;width:100%;height:100%;">
    <div style="text-align:center;max-width:20rem;padding:0 1.5rem;">
      <div style="margin-bottom:1rem;">
        <svg style="width:2rem;height:2rem;margin:0 auto 0.75rem;color:#b8732a;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path>
        </svg>
        <p style="font-family:'DM Mono',monospace;font-size:0.7rem;letter-spacing:0.15em;text-transform:uppercase;color:#8e91a4;margin-bottom:0.25rem;">temporary locked</p>
        <p style="font-family:'Cormorant Garamond',Georgia,serif;font-size:1.1rem;color:#1a1f36;">enter password to continue</p>
      </div>
      <form id="password-form" style="margin-top:1.5rem;">
        <input
          id="password-input"
          type="password"
          placeholder="password"
          style="width:100%;padding:0.625rem 1rem;font-family:'DM Mono',monospace;font-size:0.875rem;color:#1a1f36;background:#fff;border:1px solid #ddd8ce;border-radius:0.375rem;outline:none;margin-bottom:0.75rem;box-sizing:border-box;"
          autocomplete="off"
        />
        <button
          type="submit"
          style="width:100%;font-family:'DM Mono',monospace;font-size:0.7rem;letter-spacing:0.1em;text-transform:uppercase;color:#fff;background:#b8732a;padding:0.625rem;border-radius:0.375rem;border:none;cursor:pointer;"
        >
          Unlock
        </button>
        <p id="password-error" style="color:#c44b4b;font-size:0.75rem;margin-top:0.5rem;font-family:'DM Mono',monospace;display:none;">incorrect password</p>
      </form>
    </div>
  </div>
</div>

<script is:inline>
  (function() {
    var CORRECT_PASSWORD = 'Vipul@?Z?21';
    var STORAGE_KEY = 'vipulzope_unlocked';
    var lockEl = document.getElementById('password-lock');
    var form = document.getElementById('password-form');
    var input = document.getElementById('password-input');
    var error = document.getElementById('password-error');

    if (!lockEl) return;

    function showLock() {
      lockEl.style.display = 'block';
      document.body.style.overflow = 'hidden';
      document.body.style.position = 'fixed';
      document.body.style.width = '100%';
    }

    function hideLock() {
      lockEl.style.display = 'none';
      document.body.style.overflow = '';
      document.body.style.position = '';
      document.body.style.width = '';
    }

    if (sessionStorage.getItem(STORAGE_KEY) === 'true') {
      hideLock();
    } else {
      showLock();
    }

    form.addEventListener('submit', function(e) {
      e.preventDefault();
      if (input.value === CORRECT_PASSWORD) {
        sessionStorage.setItem(STORAGE_KEY, 'true');
        hideLock();
        error.style.display = 'none';
      } else {
        error.style.display = 'block';
        input.value = '';
        input.focus();
      }
    });
  })();
</script>
