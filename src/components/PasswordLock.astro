---
---

<div id="password-lock" class="fixed inset-0 z-[10000] flex items-center justify-center" style="display:none;">
  <div class="absolute inset-0 bg-[var(--color-bg)] backdrop-blur-md opacity-95"></div>
  <div class="relative z-10 text-center max-w-sm mx-auto px-6">
    <div class="mb-4">
      <svg class="w-8 h-8 mx-auto text-[var(--color-accent)] mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path>
      </svg>
      <p class="font-mono text-[0.7rem] tracking-[0.15em] uppercase text-[var(--color-ink-muted)] mb-1">temporary locked</p>
      <p class="font-serif text-[1.1rem] text-[var(--color-ink)]">enter password to continue</p>
    </div>
    <form id="password-form" class="mt-6">
      <input
        id="password-input"
        type="password"
        placeholder="password"
        class="w-full px-4 py-2.5 font-mono text-sm text-[var(--color-ink)] bg-white border border-[var(--color-border)] rounded-md focus:outline-none focus:border-[var(--color-accent)] transition-colors duration-200 mb-3"
        autocomplete="off"
      />
      <button
        type="submit"
        class="w-full font-mono text-[0.7rem] tracking-[0.1em] uppercase text-white bg-[var(--color-accent)] py-2.5 rounded-md hover:bg-[#9a6322] transition-colors duration-200 cursor-pointer"
      >
        Unlock
      </button>
      <p id="password-error" class="text-[var(--color-red)] text-xs mt-2 font-mono" style="display:none;">incorrect password</p>
    </form>
  </div>
</div>

<script is:inline>
  (function() {
    const CORRECT_PASSWORD = 'Vipul@?Z?21';
    const STORAGE_KEY = 'vipulzope_unlocked';
    const lockEl = document.getElementById('password-lock');
    const form = document.getElementById('password-form');
    const input = document.getElementById('password-input');
    const error = document.getElementById('password-error');

    if (!lockEl) return;

    function isUnlocked() {
      return sessionStorage.getItem(STORAGE_KEY) === 'true';
    }

    function showLock() {
      lockEl.style.display = 'flex';
      document.body.style.overflow = 'hidden';
    }

    function hideLock() {
      lockEl.style.display = 'none';
      document.body.style.overflow = '';
    }

    if (isUnlocked()) {
      hideLock();
    } else {
      showLock();
    }

    form.addEventListener('submit', function(e) {
      e.preventDefault();
      if (input.value === CORRECT_PASSWORD) {
        sessionStorage.setItem(STORAGE_KEY, 'true');
        hideLock();
        error.style.display = 'none';
      } else {
        error.style.display = 'block';
        input.value = '';
        input.focus();
      }
    });
  })();
</script>
