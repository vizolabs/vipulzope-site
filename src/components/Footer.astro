---
const year = new Date().getFullYear();
---
<footer class="border-t border-[var(--color-border)] py-8 mt-16">
  <div class="max-w-4xl mx-auto px-6 flex flex-col sm:flex-row items-center justify-between gap-4 text-sm text-[var(--color-text-muted)]">
    <p>&copy; {year} Vipul Zope. Built with Astro.</p>
    <div class="flex gap-4">
      <a href="https://github.com/vizolabs" target="_blank" rel="noopener" class="hover:text-[var(--color-text)] transition-colors">GitHub</a>
      <a href="mailto:contact@vipulzope.in" class="hover:text-[var(--color-text)] transition-colors">Email</a>
    </div>
  </div>
</footer>
