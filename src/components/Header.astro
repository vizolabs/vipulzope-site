---
const navItems = [
  { label: 'Home', href: '/' },
  { label: 'Blog', href: '/blog' },
  { label: 'Contact', href: '/contact' },
];
const currentPath = Astro.url.pathname;
---

<header class="max-w-[700px] mx-auto px-6 pt-6 pb-4 sm:pb-6">
  <nav class="flex items-center justify-between">
    <a
      href="/"
      class="font-serif text-lg font-semibold text-[var(--color-ink)] hover:text-[var(--color-accent)] no-underline"
    >
      Vipul Zope
    </a>
    <ul class="flex gap-5 list-none m-0 p-0">
      {navItems.map(item => {
        const isActive = currentPath === item.href || (item.href !== '/' && currentPath.startsWith(item.href));
        return (
          <li>
            <a
              href={item.href}
              class="font-mono text-xs tracking-wider no-underline transition-colors duration-200"
              class:list={{
                'text-[var(--color-accent)]': isActive,
                'text-[var(--color-ink-muted)] hover:text-[var(--color-ink)]': !isActive,
              }}
            >
              {item.label}
            </a>
          </li>
        );
      })}
    </ul>
  </nav>
</header>
