---
const navItems = [
  { label: 'Home', href: '/' },
  { label: 'Blog', href: '/blog' },
  { label: 'Contact', href: '/contact' },
];
---
<header>
  <nav class="max-w-[650px] mx-auto px-6 py-6 flex items-center justify-between">
    <a href="/" class="text-base font-medium text-[var(--color-text)] hover:text-[var(--color-accent)] no-underline">
      Vipul Zope
    </a>
    <ul class="flex gap-5">
      {navItems.map(item => (
        <li>
          <a
            href={item.href}
            class="text-sm text-[var(--color-text-muted)] hover:text-[var(--color-text)] no-underline"
          >
            {item.label}
          </a>
        </li>
      ))}
    </ul>
  </nav>
</header>
